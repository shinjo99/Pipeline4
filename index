// ─── 환율 데이터 구조 ─────────────────────────────
const THIS_YEAR = new Date().getFullYear();
const MONTHS = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
const FUTURE_YEARS = [THIS_YEAR+1, THIS_YEAR+2, THIS_YEAR+3, THIS_YEAR+4, THIS_YEAR+5];
const DEFAULT_FX = 1380;

// localStorage에서 환율 로드
function loadFXData() {
  try {
    return JSON.parse(localStorage.getItem('fx_data') || 'null') || initFXData();
  } catch(e) { return initFXData(); }
}

function initFXData() {
  const data = { monthly: {}, yearly: {} };
  // 당해년도 월별 기본값
  for (let m = 1; m <= 12; m++) {
    data.monthly[THIS_YEAR + '-' + m] = DEFAULT_FX;
  }
  // 미래 연도 연간 기본값
  FUTURE_YEARS.forEach(y => { data.yearly[y] = DEFAULT_FX; });
  return data;
}

let fxData = loadFXData();
let liveRate = null;
let showKRW = false;
let currentLang = 'ko';

// 특정 연도의 환율 반환 (당해=해당월, 미래=연간, 과거=연간 or 기본)
function getFXRate(year, month) {
  month = month || new Date().getMonth() + 1;
  if (year === THIS_YEAR) {
    return fxData.monthly[year + '-' + month] || DEFAULT_FX;
  }
  return fxData.yearly[year] || DEFAULT_FX;
}

// 현재 표시용 환율 (현재 월 기준)
function getCurrentFX() {
  return getFXRate(THIS_YEAR, new Date().getMonth() + 1);
}

function updateFXBadge() {
  const rate = getCurrentFX();
  document.getElementById('fx-rate').textContent = rate.toLocaleString() + '원';
}

// ─── 실시간 환율 조회 ─────────────────────────────
async function fetchLiveRate() {
  try {
    const res = await fetch('https://api.exchangerate-api.com/v4/latest/USD');
    const data = await res.json();
    liveRate = Math.round(data.rates.KRW);
    return liveRate;
  } catch(e) {
    return null;
  }
}

// ─── 환율 모달 ────────────────────────────────────
function openFXModal() {
  const modal = document.getElementById('fx-modal');
  modal.style.display = 'flex';
  renderFXModal();
  // 실시간 환율 조회
  document.getElementById('fx-ref-rate').textContent = '조회중...';
  fetchLiveRate().then(rate => {
    document.getElementById('fx-ref-rate').textContent =
      rate ? rate.toLocaleString() + '원' : '조회 실패';
  });
}

function closeFXModal() {
  document.getElementById('fx-modal').style.display = 'none';
}

function renderFXModal() {
  // 당해년도 월별 그리드
  document.getElementById('fx-current-year-label').textContent = THIS_YEAR + '년 월별 환율 (원)';
  const mgrid = document.getElementById('fx-monthly-grid');
  mgrid.innerHTML = MONTHS.map((m, i) => {
    const key = THIS_YEAR + '-' + (i+1);
    const val = fxData.monthly[key] || DEFAULT_FX;
    return `<div>
      <div style="font-size:10px;color:var(--t3);margin-bottom:3px">${m}</div>
      <input type="number" id="fx-m-${i+1}" value="${val}"
        style="width:100%;padding:6px 8px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--t1);font-size:12px;font-family:var(--font)"
        onchange="previewFX()">
    </div>`;
  }).join('');

  // 미래 연도 연간
  const ygrid = document.getElementById('fx-yearly-grid');
  ygrid.innerHTML = FUTURE_YEARS.map(y => {
    const val = fxData.yearly[y] || DEFAULT_FX;
    return `<div style="display:flex;align-items:center;gap:10px">
      <span style="font-size:12px;color:var(--t2);min-width:50px">${y}년</span>
      <input type="number" id="fx-y-${y}" value="${val}"
        style="flex:1;padding:6px 10px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--t1);font-size:12px;font-family:var(--font)"
        onchange="previewFX()">
      <span style="font-size:11px;color:var(--t3)">원/USD</span>
    </div>`;
  }).join('');
}

function fillFromLive() {
  if (!liveRate) { alert('실시간 환율을 먼저 조회해주세요.'); return; }
  for (let m = 1; m <= 12; m++) {
    const el = document.getElementById('fx-m-' + m);
    if (el) el.value = liveRate;
  }
  FUTURE_YEARS.forEach(y => {
    const el = document.getElementById('fx-y-' + y);
    if (el) el.value = liveRate;
  });
}

function previewFX() {
  // 미리보기: 현재 월 값으로 배지 업데이트
  const curM = new Date().getMonth() + 1;
  const el = document.getElementById('fx-m-' + curM);
  if (el && el.value) {
    document.getElementById('fx-rate').textContent = parseInt(el.value).toLocaleString() + '원';
  }
}

function saveFX() {
  const newData = { monthly: {}, yearly: {} };
  for (let m = 1; m <= 12; m++) {
    const el = document.getElementById('fx-m-' + m);
    newData.monthly[THIS_YEAR + '-' + m] = el ? parseInt(el.value) || DEFAULT_FX : DEFAULT_FX;
  }
  FUTURE_YEARS.forEach(y => {
    const el = document.getElementById('fx-y-' + y);
    newData.yearly[y] = el ? parseInt(el.value) || DEFAULT_FX : DEFAULT_FX;
  });
  fxData = newData;
  localStorage.setItem('fx_data', JSON.stringify(fxData));
  updateFXBadge();
  if (showKRW) updateCurrencyDisplay();
  closeFXModal();
}

// ─── 통화 전환 ────────────────────────────────────
function toggleCurrency() {
  showKRW = !showKRW;
  document.getElementById('currency-label').textContent = showKRW ? '₩ KRW' : '$ USD';
  document.getElementById('btn-currency').style.color = showKRW ? 'var(--amber)' : 'var(--t2)';
  updateCurrencyDisplay();
}

function updateCurrencyDisplay() {
  document.querySelectorAll('[data-usd]').forEach(el => {
    const usd = parseFloat(el.dataset.usd);
    if (showKRW) {
      const rate = getCurrentFX();
      const krw = Math.round(usd * rate / 100) / 10;
      el.textContent = krw.toLocaleString() + '억원';
    } else {
      el.textContent = '$' + usd + 'M';
    }
  });
}

