    if(state.portfolioFilter!=='all' && p.portfolio!==state.portfolioFilter) return false;
    if(state.isoFilter!=='all' && p.iso!==state.isoFilter) return false;
    if(q && !p.name.toLowerCase().includes(q) && !p.state.toLowerCase().includes(q) &&
       !p.iso.toLowerCase().includes(q) && !p.portfolio.toLowerCase().includes(q)) return false;
    return true;
  });
}

// ─── MAP ──────────────────────────────────────────────────────
let projection, path, svg, g, zoom;

function initMap() {
  const container = document.getElementById('map-container');
  const w = container.clientWidth, h = container.clientHeight;
  
  svg = d3.select('#map-svg').attr('width',w).attr('height',h);
  
  projection = d3.geoAlbersUsa().scale(w*1.1).translate([w/2, h/2]);
  path = d3.geoPath().projection(projection);
  
  zoom = d3.zoom().scaleExtent([0.8,8]).on('zoom', e => {
    g.attr('transform', e.transform);
  });
  svg.call(zoom);
  
  g = svg.append('g');
  
  const mapUrls = [
    'https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json',
    'https://unpkg.com/us-atlas@3/states-10m.json',
  ];
  
  function tryFetch(urls, idx=0){
    if(idx>=urls.length){ renderFallbackMap(); return; }
    fetch(urls[idx])
      .then(r=>{ if(!r.ok) throw new Error(r.status); return r.json(); })
      .then(us=>{
        const states = topojson.feature(us, us.objects.states);
        g.selectAll('.state-path').data(states.features).enter()
          .append('path').attr('class','state-path').attr('d',path);
        const stateNames={'01':'AL','02':'AK','04':'AZ','05':'AR','06':'CA','08':'CO','09':'CT',
          '10':'DE','12':'FL','13':'GA','15':'HI','16':'ID','17':'IL','18':'IN','19':'IA',
          '20':'KS','21':'KY','22':'LA','23':'ME','24':'MD','25':'MA','26':'MI','27':'MN',
          '28':'MS','29':'MO','30':'MT','31':'NE','32':'NV','33':'NH','34':'NJ','35':'NM',
          '36':'NY','37':'NC','38':'ND','39':'OH','40':'OK','41':'OR','42':'PA','44':'RI',
          '45':'SC','46':'SD','47':'TN','48':'TX','49':'UT','50':'VT','51':'VA','53':'WA',
          '54':'WV','55':'WI','56':'WY'};
        states.features.forEach(f=>{
          const abbr=stateNames[String(f.id).padStart(2,'0')]; if(!abbr)return;
          const c=path.centroid(f); if(!c||isNaN(c[0]))return;
          g.append('text').attr('class','state-label').attr('x',c[0]).attr('y',c[1])
            .attr('text-anchor','middle').attr('dy','.3em').text(abbr);
        });
        plotProjects();
      })
      .catch(()=>tryFetch(urls, idx+1));
  }
  
  function renderFallbackMap(){
    // 폴백: 주 위치에 배경 사각형 + 레이블 직접 그리기
    const usOutline=[[[-125,49],[-66,49],[-66,25],[-125,25],[-125,49]]];
    const usFeature={type:'Feature',geometry:{type:'Polygon',coordinates:usOutline}};
    g.append('path').datum(usFeature).attr('class','state-path').attr('d',path);
    // 주요 주 레이블
    Object.entries(STATE_COORDS).forEach(([abbr,[lat,lng]])=>{
      const pt=projection([lng,lat]); if(!pt||isNaN(pt[0]))return;
      g.append('text').attr('class','state-label').attr('x',pt[0]).attr('y',pt[1])
        .attr('text-anchor','middle').attr('dy','.3em').text(abbr).attr('font-size','9px');
    });
    plotProjects();
  }
  
  tryFetch(mapUrls);
  
  document.getElementById('zoom-in').onclick=()=>svg.transition().call(zoom.scaleBy,1.5);
  document.getElementById('zoom-out').onclick=()=>svg.transition().call(zoom.scaleBy,0.7);
  document.getElementById('zoom-reset').onclick=()=>svg.transition().call(zoom.transform,d3.zoomIdentity);
}

function plotProjects() {
  g.selectAll('.proj-marker').remove();
  const filtered = getFiltered();
  
  // Group by state+portfolio for jitter
  const stateCount = {};
  filtered.forEach(p=>{
    const key=p.state+p.portfolio;
    stateCount[key] = (stateCount[key]||0)+1;
  });
  const stateIdx = {};
  
  filtered.forEach(p=>{
    if(!STATE_COORDS[p.state]) return;
    const [lat,lng] = STATE_COORDS[p.state];
    const coords = projection([lng,lat]);
    if(!coords||isNaN(coords[0])) return;
    
    const key=p.state+p.portfolio;
    stateIdx[key] = (stateIdx[key]||0);
    const idx = stateIdx[key]++;
    const total = stateCount[key];
    // spiral jitter
    const angle = idx * 2.4; const rad = idx===0 ? 0 : 6+idx*1.5;
    const x = coords[0] + Math.cos(angle)*rad;
    const y = coords[1] + Math.sin(angle)*rad;
    
    const r = Math.max(4, Math.min(10, Math.sqrt((p.pv+p.ess)/100)*2));
    const col = PORTFOLIO_COLORS[p.portfolio]||'#888';
    const isSelected = state.selectedProject?.id === p.id;
    
    const grp = g.append('g').attr('class','proj-marker'+(isSelected?' selected':'')).attr('data-id',p.id);
    
    grp.append('circle')
      .attr('cx',x).attr('cy',y).attr('r',r)
      .attr('fill',col).attr('fill-opacity',0.85)
      .attr('stroke',isSelected?'#fff':p.type.includes('ESS')?'rgba(255,255,255,0.6)':'none')
      .attr('stroke-width',isSelected?2:1);
    
    if(isSelected){
      grp.append('circle').attr('cx',x).attr('cy',y).attr('r',r+4)
        .attr('fill','none').attr('stroke',col).attr('stroke-width',1.5).attr('opacity',0.5);
    }
    
    grp.on('mouseenter', function(event){
      const tt = document.getElementById('map-tooltip');
      const cap = document.getElementById('map-container');
      const rect = cap.getBoundingClientRect();
      const mx = event.clientX-rect.left, my = event.clientY-rect.top;
      tt.style.display='block';
      tt.style.left=(mx+12)+'px'; tt.style.top=(my-10)+'px';
      const total = p.pv+p.ess;
      tt.innerHTML=`
        <div style="font-weight:700;margin-bottom:4px">${p.name}</div>
        <div style="font-size:11px;color:#9B99A8">${p.portfolio} · ${p.state} · ${p.iso}</div>
        <div style="font-size:11px;margin-top:4px;color:#F0EFF4">${p.type} · ${total} MWac</div>
        <div style="font-size:11px;color:#9B99A8">COD: ${p.cod} · S/H: ${p.cat}</div>
      `;
    })
    .on('mouseleave', ()=>document.getElementById('map-tooltip').style.display='none')
    .on('click', ()=>selectProject(p));
  });
}

// ─── PROJECT LIST SIDEBAR ─────────────────────────────────────
// ─── 그룹 정의 ────────────────────────────────────
const DIVEST_26 = new Set([
  'Boulder Solar 3','Bonanza Peak','Oberon 2','Oberon 3','Oberon 4',
  'Taormina','Lavender','Gibson'
]);
const DIVEST_PROB = {
  'Boulder Solar 3':'H','Bonanza Peak':'M','Oberon 2':'M','Oberon 3':'M',
  'Oberon 4':'M','Taormina':'M','Lavender':'M','Gibson':'L'
};
const SH_A = new Set([
  'Borden','Keystone','Harlem River','Twinkle','Black Star','Florence'
]);
const SH_B = new Set([
  'Grandview','Stone Fruit','Midfield','Neptune','Appaloosa 2',
  'Martha Fields','Cedar Ridge','Barkley Creek','Greasewood',
  'Intermountain','Prairie Ridge'
]);
const PROB_STYLE = {
  H:'background:rgba(52,211,153,.2);color:#34D399',
  M:'background:rgba(251,191,36,.2);color:#FBBF24',
  L:'background:rgba(248,113,113,.2);color:#F87171'
};

function getGroup(p) {
  if (DIVEST_26.has(p.name)) return 'divest';
  if (SH_A.has(p.name) || SH_B.has(p.name)) return 'sh';
  return 'other';
}

function renderSidebar() {
  const filtered = getFiltered();
  document.getElementById('proj-count').textContent = filtered.length;
  const list = document.getElementById('proj-list');
  list.innerHTML = '';

  // 그룹 분류
  const gDivest = filtered.filter(p => getGroup(p) === 'divest')
    .sort((a,b) => {
      const po = {H:0,M:1,L:2};
      return (po[DIVEST_PROB[a.name]]??9) - (po[DIVEST_PROB[b.name]]??9) || a.name.localeCompare(b.name);
    });
  const gSH = filtered.filter(p => getGroup(p) === 'sh')
    .sort((a,b) => {
      const so = (p) => SH_A.has(p.name) ? 0 : 1;
      return so(a) - so(b) || a.cod - b.cod || a.name.localeCompare(b.name);
    });
  const gOther = filtered.filter(p => getGroup(p) === 'other')
    .sort((a,b) => {
      const co = {A:0,B:1,C:2,D:3,'—':4};
      return (co[a.cat]??4) - (co[b.cat]??4) || a.cod - b.cod || a.name.localeCompare(b.name);
    });

  // 그룹 접힘 상태 (기본: 모두 펼침)
  const collapsed = state.groupCollapsed || (state.groupCollapsed = {});

  function addGroup(key, label, icon, projects, badgeFn) {
    if (!projects.length) return;
    const isOpen = collapsed[key] !== true;

    // 그룹 헤더
    const hdr = document.createElement('div');
    hdr.style.cssText = 'padding:8px 10px 6px;font-size:10px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.06em;display:flex;align-items:center;justify-content:space-between;cursor:pointer;border-radius:6px;user-select:none;margin-top:4px';
    hdr.innerHTML = `
      <span style="display:flex;align-items:center;gap:5px">
        <span class="grp-arrow" style="font-size:13px;display:inline-block;transform:rotate(${isOpen?'90':'0'}deg);transition:transform .2s"">›</span>
        ${icon} ${label}
      </span>
      <span style="background:var(--surface2);padding:1px 6px;border-radius:20px;font-size:10px;color:var(--t3)">${projects.length}</span>
    `;
    hdr.onmouseenter = () => hdr.style.background = 'var(--surface2)';
    hdr.onmouseleave = () => hdr.style.background = '';

    // 아이템 컨테이너
    const container = document.createElement('div');
    container.style.cssText = `overflow:hidden;transition:max-height .25s ease;`;
    container.style.maxHeight = isOpen ? '9999px' : '0';

    projects.forEach(p => {
      const col = PORTFOLIO_COLORS[p.portfolio] || '#888';
      const item = document.createElement('div');
      item.className = 'proj-item' + (state.selectedProject?.id === p.id ? ' active' : '');
      item.innerHTML = `
        <div class="proj-dot" style="background:${col}"></div>
        <div class="proj-info">
          <div class="proj-name">${p.name}</div>
          <div class="proj-meta">${p.state} · ${p.iso} · COD ${p.cod}</div>
        </div>
        ${badgeFn(p)}
      `;
      item.onclick = () => selectProject(p);
      container.appendChild(item);
    });

    // 토글
    hdr.onclick = () => {
      const willOpen = collapsed[key] === true;
      collapsed[key] = willOpen ? false : true;
      container.style.maxHeight = willOpen ? '9999px' : '0';
      hdr.querySelector('.grp-arrow').style.transform = willOpen ? 'rotate(90deg)' : 'rotate(0deg)';
    };

    list.appendChild(hdr);
    list.appendChild(container);
  }

  addGroup('divest', LANG[currentLang].divest, '💰', gDivest, p => {
    const prob = DIVEST_PROB[p.name];
    return prob ? `<span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:20px;${PROB_STYLE[prob]}">${prob}</span>` : '';
  });

  addGroup('sh', LANG[currentLang].sh, '🏆', gSH, p => {
    const cls = SH_A.has(p.name) ? 'Class A' : 'Class B';
    const col = SH_A.has(p.name) ? 'background:rgba(74,144,226,.15);color:#4A90E2' : 'background:rgba(167,139,250,.15);color:#A78BFA';
    return `<span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:20px;${col}">${cls}</span>`;
  });

  addGroup('other', LANG[currentLang].other, '📁', gOther, () => '');
}

