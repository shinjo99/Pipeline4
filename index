// ─── Core Claude API call ─────────────────────────
// ─── API Key 관리 ─────────────────────────────────
function getApiKey() { return localStorage.getItem('claude_api_key') || ''; }

async function callClaude(messages, system='', maxTokens=1500) {
  let key = getApiKey();
  if (!key) {
    key = prompt('Anthropic API Key를 입력하세요 (sk-ant-으로 시작):');
    if (!key) throw new Error('API 키가 없습니다.');
    localStorage.setItem('claude_api_key', key);
  }
  const body = { model:'claude-sonnet-4-6', max_tokens:maxTokens, messages };
  if (system) body.system = system;
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': key,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true',
    },
    body: JSON.stringify(body)
  });
  if (res.status === 401) {
    localStorage.removeItem('claude_api_key');
    throw new Error('API 키가 올바르지 않습니다. 다시 시도하면 재입력 창이 뜹니다.');
  }
  if (!res.ok) throw new Error('API 오류 ' + res.status);
  const data = await res.json();
  return data.content.map(c => c.type === 'text' ? c.text : '').join('');
}

