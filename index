function handleDocFiles(files,p,pd,docs){
  const pending=[];
  let loaded=0;
  [...files].forEach(file=>{
    if(file.size>10*1024*1024){alert(file.name+': 10MB 초과');return;}
    const r=new FileReader();
    r.onload=e=>{
      pending.push({id:'d'+Date.now()+Math.random(),name:file.name,mime:file.type,size:file.size,data:e.target.result});
      loaded++;
      if(loaded===files.length){
        state.pendingDocs=pending;state.addingDoc=true;renderTab();
        const prev=document.getElementById('doc-preview');
        if(prev) prev.textContent=pending.map(f=>f.name).join(', ');
      }
    };
    r.readAsDataURL(file);
  });
}

function docIcon(mime){
  if(!mime)return'📄';
  if(mime.includes('pdf'))return'📑';
  if(mime.includes('word')||mime.includes('document'))return'📝';
  if(mime.includes('sheet')||mime.includes('excel'))return'📊';
  if(mime.includes('presentation')||mime.includes('powerpoint'))return'📋';
  if(mime.startsWith('image'))return'🖼️';
  return'📄';
}

// ─── SCHEDULE ────────────────────────────────────────────────
function renderSchedule(body,p,pd){
  const milestones = pd.milestones||getDefaultMilestones(p);
  const today = new Date(); today.setHours(0,0,0,0);
  const tomorrow = new Date(today); tomorrow.setDate(today.getDate()+1);
  
  const overdue = milestones.filter(m=>!m.done&&new Date(m.date)<today);
  const todayMs = milestones.filter(m=>!m.done&&new Date(m.date).toDateString()===today.toDateString());
  const soonMs  = milestones.filter(m=>!m.done&&new Date(m.date)>today&&(new Date(m.date)-today)<2*86400000);
  
  const alertMs = [...overdue,...todayMs,...soonMs];
  
  body.innerHTML=`
    ${alertMs.length>0?`
    <div class="schedule-alert-banner">
      <div class="sab-title">⚠️ 주의 필요 (${alertMs.length}건)</div>
      ${alertMs.map(m=>{
        const d=new Date(m.date); const diff=Math.round((d-today)/86400000);
        const label=diff<0?`${Math.abs(diff)}일 초과`:diff===0?'오늘':'내일';
        return `<div style="font-size:11px;color:var(--t2);margin-top:3px">• ${m.name} — <span style="color:${diff<0?'var(--red)':'var(--amber)'}">${label}</span> (${m.date})</div>`;
      }).join('')}
    </div>`:''}
    
    ${state.addingMilestone?`
    <div class="mini-modal">
      <div class="mini-modal-title">일정 추가</div>
      <div class="form-row">
        <div class="form-field" style="grid-column:1/-1"><label>마일스톤명</label><input id="ms-name" placeholder="주요 일정"></div>
      </div>
      <div class="form-row">
        <div class="form-field"><label>예정일</label><input type="date" id="ms-date"></div>
        <div class="form-field"><label>담당자</label><input id="ms-owner" placeholder="담당자"></div>
      </div>
      <div class="form-actions">
        <button class="btn-cancel" id="cancel-ms">취소</button>
        <button class="btn-save" id="save-ms">추가</button>
      </div>
    </div>`:''}
    
    <div class="milestone-list">
      ${milestones.map(m=>{
        const d=new Date(m.date); const diff=Math.round((d-today)/86400000);
        const cls=m.done?'done':diff<0?'overdue':diff===0?'today':diff<=1?'upcoming':'';
        const statusLabel=m.done?'완료':diff<0?`D+${Math.abs(diff)}`:diff===0?'오늘':diff<=1?'내일':`D-${diff}`;
        const icon=m.done?'✅':diff<0?'🚨':diff===0?'🔥':diff<=3?'⚡':'📌';
        return `<div class="milestone-item ${cls}">
          <div class="ms-icon">${icon}</div>
          <div class="ms-info">
            <div class="ms-name">${m.name}</div>
            <div class="ms-date">${m.date}${m.owner?' · '+m.owner:''}</div>
          </div>
          <span class="ms-status ${cls}">${statusLabel}</span>
          <div class="ms-actions">
            <button class="ms-toggle" data-id="${m.id}" data-done="${m.done}">${m.done?'되돌리기':'완료'}</button>
            <button class="ms-toggle" data-del="${m.id}" style="color:var(--red)">✕</button>
          </div>
        </div>`;
      }).join('')}
    </div>
    <button class="add-btn" id="add-ms-btn">+ 일정 추가</button>
  `;
  
  document.getElementById('add-ms-btn').onclick=()=>{state.addingMilestone=true;renderTab();};
  if(state.addingMilestone){
    document.getElementById('cancel-ms').onclick=()=>{state.addingMilestone=false;renderTab();};
    document.getElementById('save-ms').onclick=()=>{
      const nm=document.getElementById('ms-name').value.trim();if(!nm)return;
