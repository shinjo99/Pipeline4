let aiSearchMode = false;
let nlSearchTimer = null;

async function doNLSearch(query) {
  if(!query.trim()) { renderSidebar(); renderStats(); plotProjects(); return; }
  
  const prompt = `다음 프로젝트 목록에서 "${query}"에 해당하는 프로젝트들을 찾아주세요.

프로젝트 목록 (id: 이름, 포트폴리오, 주, ISO, COD, 유형, PV MWac, ESS MW, 카테고리):
${PROJECTS.map(p=>`${p.id}: ${p.name}, ${p.portfolio}, ${p.state}, ${p.iso}, COD${p.cod}, ${p.type}, PV:${p.pv}, ESS:${p.ess}, Cat:${p.cat}`).join('\n')}

조건에 맞는 프로젝트의 id만 JSON 배열로 반환하세요. 예: ["h01","h05","p03"]
JSON 배열만 반환하고 다른 텍스트는 없어야 합니다.`;

  try {
    const result = await callClaude([{role:'user',content:prompt}], '', 300);
    const ids = JSON.parse(result.replace(/```json|```/g,'').trim());
    state.nlSearchIds = ids;
    renderSidebar();
    renderStats();
    plotProjects();
  } catch(e) {
    console.warn('NL search failed', e);
  }
}

