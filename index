let aiOpen = false;
const aiHistory = []; // {role, content}

function toggleAI() {
  aiOpen = !aiOpen;
  document.getElementById('ai-panel').classList.toggle('open', aiOpen);
}

function appendAIMsg(role, text, isTyping=false) {
  const msgs = document.getElementById('ai-messages');
  const div = document.createElement('div');
  div.className = 'ai-msg ' + role;
  div.id = isTyping ? 'ai-typing-msg' : '';
  const avatar = role==='assistant'?'✨':'👤';
  if(isTyping) {
    div.innerHTML = `<div class="ai-msg-avatar">${avatar}</div><div class="ai-msg-bubble"><div class="ai-typing"><span></span><span></span><span></span></div></div>`;
  } else {
    // Simple markdown conversion
    const html = text
      .replace(/## (.*)/g,'<h2>$1</h2>')
      .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
      .replace(/^- (.*)/gm,'<li>$1</li>')
      .replace(/(<li>.*<\/li>)/s,'<ul>$1</ul>')
      .replace(/\n\n/g,'<br><br>')
      .replace(/\n/g,'<br>');
    div.innerHTML = `<div class="ai-msg-avatar">${avatar}</div><div class="ai-msg-bubble"><div class="ai-md">${html}</div></div>`;
  }
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  return div;
}

async function sendAIMessage(text) {
  if(!text.trim()) return;
  appendAIMsg('user', text);
  aiHistory.push({role:'user', content:text});
  document.getElementById('ai-input').value = '';
  const typingEl = appendAIMsg('assistant', '', true);
  
  try {
    const system = `당신은 재생에너지 프로젝트 투자 전문 AI 어시스트입니다.
현재 관리 중인 포트폴리오:
- HWR: ${PROJECTS.filter(p=>p.portfolio==='HWR').length}개 프로젝트, PV ${PROJECTS.filter(p=>p.portfolio==='HWR').reduce((a,p)=>a+p.pv,0).toLocaleString()} MWac, ESS ${PROJECTS.filter(p=>p.portfolio==='HWR').reduce((a,p)=>a+p.ess,0).toLocaleString()} MW
- Q-cells: ${PROJECTS.filter(p=>p.portfolio==='Q-cells').length}개 프로젝트

ISO 분포: WECC, PJM, ERCOT, MISO, CAISO, ISO-NE, NYISO, SERC, SPP
총 프로젝트: ${PROJECTS.length}개, COD 범위: 2026~2032년

한국어로 답변하세요. 구체적인 숫자와 프로젝트명을 활용하세요. 간결하고 실용적으로 답변하세요.`;

    const msgs = aiHistory.slice(-8); // last 8 turns
    const reply = await callClaude(msgs, system, 1200);
    typingEl.remove();
    appendAIMsg('assistant', reply);
    aiHistory.push({role:'assistant', content:reply});
  } catch(e) {
    typingEl.remove();
    appendAIMsg('assistant', '⚠️ API 연결 오류가 발생했습니다. 잠시 후 다시 시도해주세요.\n\n오류: ' + e.message);
  }
}

