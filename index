function applyLang() {
  const L = LANG[currentLang];

  // 검색창
  const si = document.getElementById('search-input');
  if (si) si.placeholder = L.searchPlaceholder;

  // 탑바 버튼
  const bd = document.getElementById('btn-divestment');
  const ba = document.getElementById('btn-atlas');
  const bp = document.getElementById('btn-ppa');
  if (bd) bd.textContent = L.divestBtn;
  if (ba) ba.textContent = L.atlasBtn;
  if (bp) bp.textContent = L.ppaBtn;

  // 사이드바 헤더
  const sh = document.querySelector('.sidebar-head .sidebar-section-label');
  if (sh) sh.textContent = L.projList;

  // 선택 안내 메시지
  const ns = document.querySelector('.no-selection-text');
  if (ns) ns.textContent = L.selectPrompt;

  // 상세 패널 탭
  document.querySelectorAll('.tab-btn').forEach(btn => {
    const map = {overview: L.overview, financial: L.financial, budget: L.budget, docs: L.docs, schedule: L.schedule};
    if (map[btn.dataset.tab]) btn.textContent = map[btn.dataset.tab];
  });

  // ← 파이프라인으로 버튼들
  document.querySelectorAll('[id^="close-"]').forEach(btn => {
    if (btn.tagName === 'BUTTON') btn.textContent = L.backBtn;
  });

  // 지도 범례
  document.querySelectorAll('.legend-title').forEach((el, i) => {
    el.textContent = i === 0 ? L.legendPortfolio : L.legendType;
  });

  // AI 패널
  const aiTitle = document.querySelector('.ai-panel-title');
  const aiSub   = document.querySelector('.ai-panel-sub');
  if (aiTitle) aiTitle.textContent = L.aiTitle;
  if (aiSub)   aiSub.textContent   = L.aiSub;
  const aiInput = document.getElementById('ai-input');
  if (aiInput) aiInput.placeholder = L.aiPlaceholder;
  document.querySelectorAll('.ai-qa-btn').forEach(btn => {
    const map = {report: L.aiReport, risk: L.aiRisk, cod: L.aiCod, finance: L.aiFinance};
    if (map[btn.dataset.action]) btn.textContent = map[btn.dataset.action];
  });

  // 사이드바 그룹 재렌더 (그룹명 언어 반영)
  renderSidebar();

  // 현재 열린 페이지 재렌더
  const divestPage = document.getElementById('page-divestment');
  const atlasPage  = document.getElementById('page-atlas');
  const ppaPage    = document.getElementById('page-ppa');
  if (divestPage && divestPage.style.display !== 'none') renderDivestment();
  if (atlasPage  && atlasPage.style.display  !== 'none') renderAtlas();
  if (ppaPage    && ppaPage.style.display    !== 'none') renderPPA();
}

