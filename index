<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>US Project Pipeline</title>
<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js" onerror="console.warn('D3 CDN 로딩 실패')"></script>
<script src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js" onerror="console.warn('TopoJSON CDN 로딩 실패')"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0F1117; --surface:#1A1D27; --surface2:#232636; --surface3:#2C3048;
  --border:rgba(255,255,255,.08); --border2:rgba(255,255,255,.14);
  --t1:#F0EFF4; --t2:#9B99A8; --t3:#5C5A70;
  --blue:#4A90E2; --blue-d:#2563EB; --green:#34D399; --amber:#FBBF24;
  --red:#F87171; --purple:#A78BFA;
  --hwr:#4A90E2; --pg:#34D399; --qcells:#FBBF24;
  --font:'SF Pro Display',-apple-system,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;
}
html,body{height:100%;font-family:var(--font);background:var(--bg);color:var(--t1);font-size:14px;overflow:hidden}
#root{display:flex;flex-direction:column;height:100vh}

/* TOP BAR */
.topbar{display:flex;align-items:center;gap:12px;padding:0 20px;height:52px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;z-index:10}
.tb-logo{display:flex;align-items:center;gap:8px;margin-right:8px}
.tb-logo-mark{width:28px;height:28px;background:linear-gradient(135deg,#4A90E2,#7C3AED);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff}
.tb-title{font-size:14px;font-weight:700;white-space:nowrap}
.tb-sub{font-size:11px;color:var(--t3);margin-left:4px}
.search-wrap{position:relative;flex:1;max-width:360px}
.search-wrap input{width:100%;padding:7px 12px 7px 34px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--t1);font-size:13px;font-family:var(--font)}
.search-wrap input:focus{outline:none;border-color:var(--blue)}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:14px}
.tb-filters{display:flex;gap:4px}
.fchip{padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;border:1px solid var(--border2);background:none;color:var(--t2);cursor:pointer;font-family:var(--font)}
.fchip:hover{background:var(--surface2)}
.fchip.active{color:#fff;border-color:transparent}
.fchip.hwr.active{background:var(--hwr)}
.fchip.pg.active{background:var(--pg);color:#000}
.fchip.qcells.active{background:var(--qcells);color:#000}
.fchip.all.active{background:var(--surface3)}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.alert-btn{position:relative;width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:var(--surface2);border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:14px}
.alert-dot{position:absolute;top:4px;right:4px;width:8px;height:8px;background:var(--red);border-radius:50%;border:2px solid var(--surface)}
.stats-bar{display:flex;gap:12px;font-size:12px}
.stat-item{color:var(--t3)} .stat-item strong{color:var(--t1);font-weight:600}

/* MAIN LAYOUT */
.main{display:flex;flex:1;min-height:0}

/* SIDEBAR */
.sidebar{width:260px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sidebar-head{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.sidebar-head-title{font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.06em}
.project-count{font-size:11px;color:var(--t3);background:var(--surface2);padding:2px 7px;border-radius:20px}
.project-list{flex:1;overflow-y:auto;padding:6px}
.project-list::-webkit-scrollbar{width:4px} .project-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.proj-item{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:background .1s;border:1px solid transparent}
.proj-item:hover{background:var(--surface2)}
.proj-item.active{background:var(--surface2);border-color:var(--border2)}
.proj-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.proj-info{flex:1;min-width:0}
.proj-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.proj-meta{font-size:10px;color:var(--t3);margin-top:1px}
.proj-cap{font-size:11px;color:var(--t2);flex-shrink:0}
.cat-badge{font-size:9px;font-weight:700;padding:1px 5px;border-radius:4px;background:var(--surface3);color:var(--t2)}
.cat-A{color:#F59E0B;background:rgba(245,158,11,.15)} .cat-B{color:#4A90E2;background:rgba(74,144,226,.15)} .cat-C{color:#A78BFA;background:rgba(167,139,250,.15)} .cat-D{color:#34D399;background:rgba(52,211,153,.15)}

/* MAP */
.map-container{flex:1;position:relative;overflow:hidden;background:var(--bg)}
#map-svg{width:100%;height:100%}
.state-path{fill:#1E2235;stroke:#2C3048;stroke-width:.5}
.state-path:hover{fill:#252840}
.state-label{font-size:8px;fill:#3C4060;font-family:var(--font);pointer-events:none;user-select:none}
.proj-marker{cursor:pointer;transition:all .15s}
.proj-marker circle{transition:all .15s}
.proj-marker:hover circle{filter:brightness(1.3)}
.proj-marker.selected circle{stroke-width:2.5;filter:brightness(1.3)}
.map-tooltip{position:absolute;background:var(--surface);border:1px solid var(--border2);border-radius:8px;padding:10px 12px;pointer-events:none;font-size:12px;min-width:160px;z-index:100;box-shadow:0 8px 24px rgba(0,0,0,.5)}
.map-legend{position:absolute;bottom:16px;left:16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;font-size:11px}
.legend-title{font-size:10px;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.legend-row{display:flex;align-items:center;gap:6px;margin-bottom:4px;color:var(--t2)}
.map-zoom{position:absolute;top:16px;right:16px;display:flex;flex-direction:column;gap:4px}
.zoom-btn{width:28px;height:28px;background:var(--surface);border:1px solid var(--border);border-radius:6px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;color:var(--t2)}
.zoom-btn:hover{background:var(--surface2);color:var(--t1)}
.iso-filter-bar{position:absolute;top:16px;left:50%;transform:translateX(-50%);display:flex;gap:4px;background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:4px 6px}
.iso-chip{padding:3px 10px;border-radius:20px;font-size:11px;cursor:pointer;color:var(--t3);font-family:var(--font)}
.iso-chip:hover{color:var(--t1)} .iso-chip.active{background:var(--surface2);color:var(--t1);font-weight:600}

/* DETAIL PANEL */
.detail-panel{width:420px;flex-shrink:0;background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;transform:translateX(100%);transition:transform .25s ease;position:absolute;right:0;top:0;bottom:0;z-index:20}
.detail-panel.open{transform:translateX(0)}
.dp-header{padding:14px 16px;border-bottom:1px solid var(--border);flex-shrink:0}
.dp-close{float:right;background:none;border:none;color:var(--t3);cursor:pointer;font-size:16px;line-height:1}
.dp-close:hover{color:var(--t1)}
.dp-portfolio{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px}
.dp-name{font-size:18px;font-weight:700;line-height:1.2;margin-bottom:6px}
.dp-chips{display:flex;gap:5px;flex-wrap:wrap}
.dp-chip{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;background:var(--surface2);color:var(--t2)}
.dp-tabs{display:flex;border-bottom:1px solid var(--border);padding:0 16px;flex-shrink:0;overflow-x:auto}
.dp-tab{padding:9px 12px;font-size:12px;background:none;border:none;border-bottom:2px solid transparent;color:var(--t3);cursor:pointer;white-space:nowrap;font-family:var(--font);margin-bottom:-1px}
.dp-tab:hover{color:var(--t1)} .dp-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
.dp-body{flex:1;overflow-y:auto;padding:16px}
.dp-body::-webkit-scrollbar{width:4px} .dp-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* OVERVIEW TAB */
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.info-item{background:var(--surface2);border-radius:8px;padding:10px 12px}
.info-label{font-size:10px;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px}
.info-value{font-size:14px;font-weight:600}
.info-value.green{color:var(--green)} .info-value.blue{color:var(--blue)} .info-value.amber{color:var(--amber)}
.section-title{font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;margin-top:14px}
.overview-desc{font-size:13px;color:var(--t2);line-height:1.6;background:var(--surface2);border-radius:8px;padding:12px;min-height:60px}
.overview-desc[contenteditable="true"]:focus{outline:1px solid var(--blue)}
.save-note{font-size:11px;color:var(--t3);margin-top:4px}

/* FINANCIAL MODEL */
.fin-section{background:var(--surface2);border-radius:10px;padding:14px;margin-bottom:10px}
.fin-section-title{font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}
.fin-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.fin-field{display:flex;flex-direction:column;gap:3px}
.fin-field label{font-size:10px;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.03em}
.fin-field input,.fin-field select{padding:6px 9px;background:var(--surface3);border:1px solid var(--border2);border-radius:6px;color:var(--t1);font-size:12px;font-family:var(--font)}
.fin-field input:focus,.fin-field select:focus{outline:none;border-color:var(--blue)}
.fin-results{background:var(--surface3);border-radius:10px;padding:14px;border:1px solid var(--border2)}
.fin-results-title{font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}
.fin-result-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px}
.fin-result-item{text-align:center;padding:10px 6px;background:var(--surface2);border-radius:8px}
.fin-result-label{font-size:10px;color:var(--t3);margin-bottom:3px}
.fin-result-val{font-size:18px;font-weight:800}
.fin-result-val.good{color:var(--green)} .fin-result-val.ok{color:var(--amber)} .fin-result-val.bad{color:var(--red)}
.fin-calc-btn{width:100%;padding:9px;background:var(--blue-d);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;font-family:var(--font);cursor:pointer;margin-top:8px}
.fin-calc-btn:hover{opacity:.9}
.cashflow-table{width:100%;border-collapse:collapse;font-size:11px;margin-top:8px}
.cashflow-table th{padding:5px 8px;background:var(--surface3);color:var(--t3);text-align:right;font-weight:600}
.cashflow-table th:first-child{text-align:left}
.cashflow-table td{padding:4px 8px;border-top:1px solid var(--border);color:var(--t2);text-align:right}
.cashflow-table td:first-child{text-align:left;color:var(--t1)}
.cf-pos{color:var(--green)!important} .cf-neg{color:var(--red)!important}

/* BUDGET */
.budget-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px}
.budget-card{background:var(--surface2);border-radius:8px;padding:10px 12px;text-align:center}
.budget-card-label{font-size:10px;color:var(--t3);margin-bottom:4px}
.budget-card-val{font-size:16px;font-weight:700}
.budget-progress{margin-bottom:12px}
.bp-label{display:flex;justify-content:space-between;font-size:11px;color:var(--t2);margin-bottom:4px}
.bp-bar{height:6px;background:var(--surface3);border-radius:3px;overflow:hidden}
.bp-fill{height:100%;border-radius:3px;background:var(--blue);transition:width .4s}
.bp-fill.over{background:var(--red)}
.budget-list{display:flex;flex-direction:column;gap:4px}
.budget-item{display:grid;grid-template-columns:1fr 80px 80px 80px;gap:6px;align-items:center;padding:8px 10px;background:var(--surface2);border-radius:7px;font-size:12px}
.budget-item-name{font-weight:500}
.budget-item-val{text-align:right;color:var(--t2)}
.budget-item-actual{text-align:right}
.budget-item-pct{text-align:right;font-size:11px}
.add-btn{display:flex;align-items:center;gap:5px;padding:7px 12px;background:none;border:1px dashed var(--border2);border-radius:7px;color:var(--t3);cursor:pointer;font-size:12px;font-family:var(--font);width:100%;justify-content:center;margin-top:6px}
.add-btn:hover{border-color:var(--blue);color:var(--blue)}

/* DOCUMENTS */
.doc-upload-zone{border:1.5px dashed var(--border2);border-radius:8px;padding:20px;text-align:center;cursor:pointer;transition:all .15s;margin-bottom:10px}
.doc-upload-zone:hover,.dz-over{border-color:var(--blue);background:rgba(74,144,226,.04)}
.duz-icon{font-size:28px;margin-bottom:6px}
.duz-text{font-size:13px;color:var(--t2)} .duz-link{color:var(--blue);text-decoration:underline;cursor:pointer}
.duz-hint{font-size:11px;color:var(--t3);margin-top:3px}
.doc-category-filter{display:flex;gap:4px;margin-bottom:8px;flex-wrap:wrap}
.doc-cat-btn{padding:3px 9px;border-radius:20px;font-size:11px;border:1px solid var(--border);background:none;color:var(--t3);cursor:pointer;font-family:var(--font)}
.doc-cat-btn.active{background:var(--surface2);color:var(--t1)}
.doc-list{display:flex;flex-direction:column;gap:4px}
.doc-item{display:flex;align-items:center;gap:8px;padding:9px 10px;background:var(--surface2);border-radius:8px;font-size:12px}
.doc-icon{font-size:18px;flex-shrink:0}
.doc-info{flex:1;min-width:0}
.doc-name{font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.doc-meta{font-size:10px;color:var(--t3);margin-top:1px}
.doc-actions{display:flex;gap:4px;flex-shrink:0}
.doc-btn{padding:3px 8px;background:none;border:1px solid var(--border);border-radius:5px;font-size:10px;cursor:pointer;color:var(--t2);font-family:var(--font)}
.doc-btn:hover{background:var(--surface3);color:var(--t1)}
.doc-category-badge{font-size:9px;padding:1px 6px;border-radius:20px;background:var(--surface3);color:var(--t3);margin-right:4px}

/* SCHEDULE */
.schedule-alert-banner{background:rgba(248,113,113,.12);border:1px solid rgba(248,113,113,.3);border-radius:8px;padding:10px 12px;margin-bottom:10px;font-size:12px}
.sab-title{font-weight:700;color:var(--red);margin-bottom:4px;display:flex;align-items:center;gap:5px}
.milestone-list{display:flex;flex-direction:column;gap:6px}
.milestone-item{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--border2)}
.milestone-item.overdue{border-left-color:var(--red)}
.milestone-item.today{border-left-color:var(--amber)}
.milestone-item.upcoming{border-left-color:var(--blue)}
.milestone-item.done{border-left-color:var(--green);opacity:.6}
.ms-icon{font-size:16px;flex-shrink:0}
.ms-info{flex:1}
.ms-name{font-size:13px;font-weight:500}
.ms-date{font-size:11px;color:var(--t3);margin-top:1px}
.ms-status{font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;flex-shrink:0}
.ms-status.overdue{background:rgba(248,113,113,.15);color:var(--red)}
.ms-status.today{background:rgba(251,191,36,.15);color:var(--amber)}
.ms-status.upcoming{background:rgba(74,144,226,.15);color:var(--blue)}
.ms-status.done{background:rgba(52,211,153,.15);color:var(--green)}
.ms-actions{display:flex;gap:4px}
.ms-toggle{padding:3px 8px;background:none;border:1px solid var(--border);border-radius:5px;font-size:10px;cursor:pointer;color:var(--t2);font-family:var(--font)}
.ms-toggle:hover{background:var(--surface3)}

/* INPUTS & FORMS */
input,textarea,select{background:var(--surface2);border:1px solid var(--border2);border-radius:6px;color:var(--t1);font-family:var(--font)}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--blue)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}
.form-field{display:flex;flex-direction:column;gap:3px}
.form-field label{font-size:10px;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.03em}
.form-field input,.form-field select{padding:6px 9px;font-size:12px}
.form-actions{display:flex;justify-content:flex-end;gap:6px;margin-top:10px}
.btn-cancel{padding:6px 13px;background:none;border:1px solid var(--border2);border-radius:7px;color:var(--t2);cursor:pointer;font-size:12px;font-family:var(--font)}
.btn-save{padding:6px 16px;background:var(--blue-d);color:#fff;border:none;border-radius:7px;cursor:pointer;font-size:12px;font-weight:600;font-family:var(--font)}
.mini-modal{background:var(--surface2);border-radius:10px;padding:14px;margin-bottom:10px;border:1px solid var(--border2)}
.mini-modal-title{font-size:12px;font-weight:700;margin-bottom:10px}

/* ALERT PANEL */
.alert-panel{position:absolute;top:52px;right:0;width:320px;background:var(--surface);border:1px solid var(--border2);border-radius:0 0 10px 10px;z-index:50;box-shadow:0 16px 48px rgba(0,0,0,.6);max-height:400px;overflow-y:auto;display:none}
.alert-panel.open{display:block}
.alert-panel-head{padding:12px 14px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700}
.alert-entry{display:flex;align-items:flex-start;gap:8px;padding:10px 14px;border-bottom:1px solid var(--border)}
.ae-icon{font-size:16px;flex-shrink:0;margin-top:1px}
.ae-info .ae-title{font-size:12px;font-weight:600}
.ae-info .ae-sub{font-size:11px;color:var(--t3);margin-top:1px}

/* NO SELECTION */
.no-selection{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:var(--t3);gap:10px}
.no-selection-icon{font-size:48px;opacity:.3}
.no-selection-text{font-size:14px}

@media(max-width:900px){
  .sidebar{width:200px}
  .detail-panel{width:360px}
}

/* ── AI PANEL ── */
.ai-fab{position:fixed;bottom:24px;right:24px;width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#6366F1,#8B5CF6);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 4px 24px rgba(99,102,241,.5);z-index:300;transition:transform .2s,box-shadow .2s}
.ai-fab:hover{transform:scale(1.08);box-shadow:0 6px 32px rgba(99,102,241,.7)}
.ai-fab .ai-fab-badge{position:absolute;top:-2px;right:-2px;width:16px;height:16px;background:var(--red);border-radius:50%;font-size:9px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;border:2px solid var(--bg);display:none}
.ai-panel{position:fixed;bottom:88px;right:24px;width:420px;max-width:calc(100vw - 48px);background:var(--surface);border:1px solid rgba(99,102,241,.3);border-radius:16px;box-shadow:0 16px 64px rgba(0,0,0,.6);z-index:299;display:flex;flex-direction:column;overflow:hidden;transform:translateY(20px) scale(.95);opacity:0;pointer-events:none;transition:all .2s ease}
.ai-panel.open{transform:translateY(0) scale(1);opacity:1;pointer-events:all}
.ai-panel-header{padding:14px 16px;background:linear-gradient(135deg,rgba(99,102,241,.15),rgba(139,92,246,.15));border-bottom:1px solid rgba(99,102,241,.2);display:flex;align-items:center;gap:10px}
.ai-panel-icon{font-size:20px}
.ai-panel-title{flex:1;font-size:13px;font-weight:700}
.ai-panel-sub{font-size:10px;color:var(--t3)}
.ai-panel-close{background:none;border:none;color:var(--t3);cursor:pointer;font-size:16px;padding:2px 6px}
.ai-panel-close:hover{color:var(--t1)}
.ai-quick-actions{display:flex;gap:6px;padding:10px 12px;flex-wrap:wrap;border-bottom:1px solid var(--border)}
.ai-qa-btn{display:flex;align-items:center;gap:5px;padding:5px 10px;background:var(--surface2);border:1px solid var(--border2);border-radius:20px;font-size:11px;color:var(--t2);cursor:pointer;font-family:var(--font);transition:all .1s;white-space:nowrap}
.ai-qa-btn:hover{background:rgba(99,102,241,.15);border-color:rgba(99,102,241,.4);color:var(--t1)}
.ai-messages{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:10px;min-height:200px;max-height:340px}
.ai-messages::-webkit-scrollbar{width:3px}.ai-messages::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.ai-msg{display:flex;gap:8px;align-items:flex-start}
.ai-msg.user{flex-direction:row-reverse}
.ai-msg-avatar{width:26px;height:26px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px}
.ai-msg.assistant .ai-msg-avatar{background:linear-gradient(135deg,#6366F1,#8B5CF6)}
.ai-msg.user .ai-msg-avatar{background:var(--surface3);font-size:10px}
.ai-msg-bubble{max-width:85%;padding:9px 12px;border-radius:12px;font-size:12px;line-height:1.6}
.ai-msg.assistant .ai-msg-bubble{background:var(--surface2);color:var(--t1);border-radius:4px 12px 12px 12px}
.ai-msg.user .ai-msg-bubble{background:rgba(99,102,241,.2);color:var(--t1);border-radius:12px 4px 12px 12px}
.ai-msg-bubble strong{color:var(--blue)}
.ai-msg-bubble .ai-md h2{font-size:12px;font-weight:700;margin:8px 0 4px;color:var(--t1)}
.ai-msg-bubble .ai-md ul{padding-left:14px;margin:4px 0}
.ai-msg-bubble .ai-md li{margin:2px 0;color:var(--t2)}
.ai-msg-bubble .ai-md p{margin:4px 0;color:var(--t2)}
.ai-typing{display:flex;gap:4px;align-items:center;padding:4px 0}
.ai-typing span{width:6px;height:6px;background:var(--t3);border-radius:50%;animation:bounce .8s infinite}
.ai-typing span:nth-child(2){animation-delay:.15s}.ai-typing span:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-6px)}}
.ai-input-row{display:flex;gap:8px;padding:10px 12px;border-top:1px solid var(--border)}
.ai-input{flex:1;padding:8px 12px;background:var(--surface2);border:1px solid var(--border2);border-radius:20px;color:var(--t1);font-size:12px;font-family:var(--font);resize:none;max-height:80px}
.ai-input:focus{outline:none;border-color:rgba(99,102,241,.5)}
.ai-send{width:34px;height:34px;background:linear-gradient(135deg,#6366F1,#8B5CF6);border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;align-self:flex-end}
.ai-send:hover{opacity:.88}
/* Doc AI result */
.ai-doc-result{background:linear-gradient(135deg,rgba(99,102,241,.08),rgba(139,92,246,.08));border:1px solid rgba(99,102,241,.2);border-radius:10px;padding:12px;margin-top:8px;font-size:12px;line-height:1.7;color:var(--t2)}
.ai-doc-result-title{font-size:11px;font-weight:700;color:rgba(139,92,246,.9);margin-bottom:8px;display:flex;align-items:center;gap:5px}
.ai-analyze-btn{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.3);border-radius:20px;font-size:10px;color:rgba(139,92,246,.9);cursor:pointer;font-family:var(--font);transition:all .15s}
.ai-analyze-btn:hover{background:rgba(99,102,241,.25)}
.ai-analyze-btn.loading{opacity:.6;pointer-events:none}
/* NL search */
.search-ai-toggle{padding:4px 8px;background:rgba(99,102,241,.15);border:1px solid rgba(99,102,241,.3);border-radius:6px;font-size:10px;color:rgba(139,92,246,.9);cursor:pointer;font-family:var(--font);white-space:nowrap;flex-shrink:0}
.search-ai-toggle.active{background:rgba(99,102,241,.3)}
.search-ai-hint{font-size:10px;color:rgba(139,92,246,.7);position:absolute;right:10px;top:50%;transform:translateY(-50%);pointer-events:none}
