  document.getElementById('ppa-funnel').innerHTML = stages.map(s=>`
    <div style="flex:1;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px;text-align:center">
      <div style="font-size:10px;color:var(--t3);margin-bottom:4px">${s === '계약' ? contractLabel : s}</div>
      <div style="font-size:22px;font-weight:800;color:${colors[s]}">${cnt(s)}</div>
    </div>`).join('');

  // 테이블
  document.getElementById('ppa-table').innerHTML = `
    <thead>
      <tr style="border-bottom:1px solid var(--border)">
        ${[L.ppaColProj, L.ppaColIso, L.ppaColState, L.ppaColStage, L.ppaColNote]
          .map(h=>`<th style="padding:10px 14px;background:var(--surface2);font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.04em;text-align:left">${h}</th>`).join('')}
      </tr>
    </thead>
    <tbody>
      ${PPA_DATA.map(p=>`
        <tr style="border-bottom:1px solid var(--border)">
          <td style="padding:10px 14px;font-weight:600">${p.name}</td>
          <td style="padding:10px 14px;color:var(--t2)">${p.iso}</td>
          <td style="padding:10px 14px;color:var(--t2)">${p.state}</td>
          <td style="padding:10px 14px">
            <select data-ppa-id="${p.id}" style="padding:3px 8px;border-radius:20px;border:none;cursor:pointer;font-size:11px;font-weight:700;font-family:var(--font);${PPA_STAGE_STYLE[p.stage]||PPA_STAGE_STYLE['']}">
              <option value=""    ${p.stage===''    ?'selected':''}>—</option>
              <option value="RFP" ${p.stage==='RFP' ?'selected':''}>RFP</option>
              <option value="SL"  ${p.stage==='SL'  ?'selected':''}>SL</option>
              <option value="BL"  ${p.stage==='BL'  ?'selected':''}>BL</option>
              <option value="계약" ${p.stage==='계약'?'selected':''}>${contractLabel}</option>
            </select>
          </td>
          <td style="padding:10px 14px;font-size:11px;color:var(--t2)">${p.note}</td>
        </tr>`).join('')}
    </tbody>`;

  // 단계 변경 이벤트
  document.querySelectorAll('[data-ppa-id]').forEach(sel => {
    sel.onchange = () => {
      const p = PPA_DATA.find(x => x.id === sel.dataset.ppaId);
      if (p) { p.stage = sel.value; savePPA(); renderPPA(); }
    };
  });
}

document.getElementById('btn-ppa').addEventListener('click', () => {
  document.getElementById('page-ppa').style.display = 'block';
  renderPPA();
});
document.getElementById('close-ppa').addEventListener('click', () => {
  document.getElementById('page-ppa').style.display = 'none';
});
</script>

<style>
.tb-page-btn {
  padding:5px 12px;
  background:rgba(52,211,153,.12);
  border:1px solid rgba(52,211,153,.3);
  border-radius:8px;font-size:12px;font-weight:600;
  color:#34D399;cursor:pointer;font-family:var(--font);
  transition:all .15s;white-space:nowrap;
}
.tb-page-btn:hover { background:rgba(52,211,153,.22); }
</style>
</body>
</html>
