function renderAtlas() {
  const L = LANG[currentLang];
  const today = new Date();
  const done    = ATLAS_MS.filter(m=>m.status==='done').length;
  const partial = ATLAS_MS.filter(m=>m.status==='partial').length;
  const pct = Math.round((done + partial*0.5) / ATLAS_MS.length * 100);

  const STATUS = {
    done:    {label: currentLang==='ko'?'완료':'Done',       cls:'background:rgba(52,211,153,.15);color:#34D399'},
    partial: {label:'Partially',                              cls:'background:rgba(251,191,36,.15);color:#FBBF24'},
    progress:{label: currentLang==='ko'?'진행중':'In Progress', cls:'background:rgba(74,144,226,.15);color:#4A90E2'},
    pending: {label: currentLang==='ko'?'미착수':'Pending',   cls:'background:var(--surface2);color:var(--t3)'},
  };

  // 페이지 제목
  const atTitle = document.querySelector('#page-atlas .atlas-page-title');
  const atSub   = document.querySelector('#page-atlas .atlas-page-sub');
  if (atTitle) atTitle.textContent = L.atlasTitle;
  if (atSub)   atSub.textContent   = L.atlasSub;
  document.getElementById('close-atlas').textContent = L.backBtn;

  // KPI
  document.getElementById('atlas-kpi').innerHTML = [
    {label: L.atlasTotal, val:ATLAS_MS.length,             color:'var(--t1)'},
    {label: L.atlasDone,  val:done,                        color:'var(--green)'},
    {label:'Partially',   val:partial,                      color:'var(--amber)'},
    {label: L.atlasPending, val:ATLAS_MS.length-done-partial, color:'var(--t3)'},
  ].map(k=>`
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 16px">
      <div style="font-size:11px;color:var(--t3);margin-bottom:5px">${k.label}</div>
      <div style="font-size:26px;font-weight:800;color:${k.color}">${k.val}</div>
    </div>`).join('');

  // 진행바
  document.getElementById('atlas-progress-bar').innerHTML = `
    <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--t2);margin-bottom:8px">
      <span>${L.atlasRate}</span><span style="font-weight:700;color:var(--blue)">${pct}%</span>
    </div>
    <div style="height:8px;background:var(--surface3);border-radius:4px;overflow:hidden">
      <div style="width:${pct}%;height:100%;background:var(--blue);border-radius:4px;transition:width .4s"></div>
    </div>`;

  // 항목 리스트
  document.getElementById('atlas-list').innerHTML = `
    <div style="display:grid;grid-template-columns:160px 130px 80px 1fr;gap:10px;padding:6px 14px;font-size:10px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.04em;background:var(--surface);border:1px solid var(--border);border-radius:10px 10px 0 0;border-bottom:none">
      <span>${L.atlasColItem}</span><span>${L.atlasColTarget}</span><span>${L.atlasColDday}</span><span>${L.atlasColStatus}</span>
    </div>
    ${ATLAS_MS.map((m,i) => {
      const d = new Date(m.target);
      const diff = Math.round((d - today) / 86400000);
      const todayLabel = currentLang==='ko' ? '오늘' : 'Today';
      const dday = diff < 0  ? `<span style="color:var(--red)">D+${Math.abs(diff)}</span>`
                 : diff === 0 ? `<span style="color:var(--amber)">${todayLabel}</span>`
                 : diff <= 7  ? `<span style="color:var(--amber)">D-${diff}</span>`
                 :               `<span style="color:var(--t3)">D-${diff}</span>`;
      const st = STATUS[m.status] || STATUS.pending;
      const isLast = i === ATLAS_MS.length - 1;
      return `
        <div style="display:grid;grid-template-columns:160px 130px 80px 1fr;gap:10px;align-items:center;padding:10px 14px;background:var(--surface);border:1px solid var(--border);${isLast?'border-radius:0 0 10px 10px':'border-bottom:none'}">
          <div>
            <div style="font-size:11px;font-weight:700;color:var(--t1)">${m.item}</div>
            <div style="font-size:11px;color:var(--t3);margin-top:1px">${m.name}</div>
          </div>
          <div style="font-size:12px;color:var(--t2)">${m.target}</div>
          <div style="font-size:12px">${dday}</div>
          <div>
            <select data-atlas-id="${m.id}" style="padding:3px 8px;border-radius:20px;border:none;cursor:pointer;font-size:11px;font-weight:700;font-family:var(--font);${st.cls}">
              <option value="done"     ${m.status==='done'    ?'selected':''}>완료</option>
              <option value="partial"  ${m.status==='partial' ?'selected':''}>Partially</option>
              <option value="progress" ${m.status==='progress'?'selected':''}>진행중</option>
              <option value="pending"  ${m.status==='pending' ?'selected':''}>미착수</option>
            </select>
          </div>
        </div>`;
    }).join('')}`;

  // 상태 변경 이벤트
  document.querySelectorAll('[data-atlas-id]').forEach(sel => {
    sel.onchange = () => {
      const m = ATLAS_MS.find(x => x.id === sel.dataset.atlasId);
      if (m) { m.status = sel.value; saveAtlas(); renderAtlas(); }
    };
  });
}

