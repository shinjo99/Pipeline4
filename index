// ─── AI Document Analysis ─────────────────────────
async function analyzeDocument(doc, project) {
  const btn = document.getElementById('analyze-btn-'+doc.id);
  if(btn){ btn.classList.add('loading'); btn.textContent='분석 중...'; }
  
  try {
    let content = [];
    if(doc.data) {
      if(doc.mime === 'application/pdf') {
        content.push({type:'document', source:{type:'base64', media_type:'application/pdf', data:doc.data.split(',')[1]}});
      } else if(doc.mime.startsWith('image/')) {
        content.push({type:'image', source:{type:'base64', media_type:doc.mime, data:doc.data.split(',')[1]}});
      }
    }
    content.push({type:'text', text:`
이 문서는 "${project.name}" 프로젝트(${project.state}, ${project.iso}, ${project.type}, COD ${project.cod})의 ${doc.category}입니다.

다음을 간결하게 분석해주세요:
1. 📋 **문서 요약** (2-3줄)
2. ⚠️ **주요 리스크 조항** (페널티, 해지 조건, 의무사항 등)
3. 📅 **핵심 날짜/기한**
4. 💰 **금액/가격 조건** (있는 경우)
5. 🔑 **특이사항 및 검토 필요 항목**

한국어로 답변하세요. 없는 항목은 "해당없음"으로 표시하세요.`});

    const result = await callClaude([{role:'user', content}], '', 1000);
    
    // Show result in UI
    const existingResult = document.getElementById('ai-result-'+doc.id);
    if(existingResult) existingResult.remove();
    
    const resultDiv = document.createElement('div');
    resultDiv.id = 'ai-result-'+doc.id;
    resultDiv.className = 'ai-doc-result';
    const html = result.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>');
    resultDiv.innerHTML = `<div class="ai-doc-result-title">✨ AI 분석 결과</div>${html}`;
    
    const docItem = document.querySelector(`[data-doc-id="${doc.id}"]`);
    if(docItem) docItem.after(resultDiv);
    
  } catch(e) {
    alert('분석 실패: '+e.message);
  }
  
  if(btn){ btn.classList.remove('loading'); btn.textContent='✨ AI 분석'; }
}

