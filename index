// ─── IRR SOLVER ───────────────────────────────────────────────
function npv(rate, cfs) {
  return cfs.reduce((acc,cf,t) => acc + cf/Math.pow(1+rate,t), 0);
}
function irr(cfs) {
  let lo=-0.999, hi=10;
  if(npv(lo,cfs)*npv(hi,cfs)>0) return null;
  for(let i=0;i<1000;i++){
    const mid=(lo+hi)/2;
    if(Math.abs(hi-lo)<1e-8) return mid;
    if(npv(lo,cfs)*npv(mid,cfs)<0) hi=mid; else lo=mid;
  }
  return (lo+hi)/2;
}
function calcFinancials(params) {
  const {capex,opex,pvMW,essMW,cf,ppaPrice,ppaPct,merchantPrice,life,debtRatio,debtRate,debtTerm,opexEsc} = params;
  const annualEnergy = pvMW * (cf/100) * 8760 / 1000; // GWh
  const annualRevPV = annualEnergy * 1000 * (ppaPct/100 * ppaPrice + (1-ppaPct/100) * merchantPrice) / 1e6; // $M
  const annualRevESS = essMW * 365 * 4 * (merchantPrice * 0.8) / 1e6; // rough ESS revenue $M
  
  const pirCFs = [-capex];
  const debtAmt = capex * debtRatio/100;
  const equityAmt = capex * (1-debtRatio/100);
  const debtService = debtAmt * (debtRate/100 * Math.pow(1+debtRate/100,debtTerm)) / (Math.pow(1+debtRate/100,debtTerm)-1);
  const eirCFs = [-equityAmt];

  for(let yr=1; yr<=life; yr++){
    const rev = (annualRevPV + annualRevESS) * Math.pow(0.995, yr-1); // 0.5% degradation
    const op = opex * Math.pow(1+opexEsc/100, yr-1);
    const ebitda = rev - op;
    pirCFs.push(ebitda);
    const ds = yr <= debtTerm ? debtService : 0;
    eirCFs.push(ebitda - ds);
  }

  const pIRR = irr(pirCFs);
  const eIRR = irr(eirCFs);
  const avgRev = (annualRevPV+annualRevESS);
  const avgOp = opex;
  const avgDS = debtService * Math.min(debtTerm, life) / life;
  const margin = avgRev>0 ? (avgRev-avgOp-avgDS)/avgRev*100 : 0;
  
  return {
    pIRR: pIRR ? (pIRR*100).toFixed(2) : 'N/A',
    eIRR: eIRR ? (eIRR*100).toFixed(2) : 'N/A',
    margin: margin.toFixed(1),
    annualRev: (annualRevPV+annualRevESS).toFixed(2),
    ebitda: (annualRevPV+annualRevESS-opex).toFixed(2),
    cashflows: pirCFs.slice(0, Math.min(6, pirCFs.length)),
  };
}

